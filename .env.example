# OpenWeatherMap API key — required for real weather data
# Get one free at https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# TfL Unified API key — optional, unauthenticated requests are rate-limited
# Register at https://api.tfl.gov.uk
TFL_API_KEY=your_tfl_api_key_here

# Comma-separated origins allowed by the FastAPI CORS middleware
# Leave empty to allow all origins (fine for local development)
ALLOWED_ORIGINS=http://localhost:8501
