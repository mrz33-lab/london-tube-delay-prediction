# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Model artifacts (large binary files) ──────────────────────────────────────
# Keep metrics, plots, and CSVs; exclude large pickled models
artifacts/*/naive_model.pkl
artifacts/*/ridge_model.pkl
artifacts/*/best_model.pkl
artifacts/*/feature_metadata.pkl

# Exclude all run directories except the two canonical ones
artifacts/run_20260310_154543/
artifacts/run_20260310_155058/
artifacts/run_20260310_155138/
artifacts/run_20260310_155155/
artifacts/run_20260310_163553/

# Keep the artifacts folder structure itself
!artifacts/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
artifacts/*/run.log

# ── Real data (may be large or sensitive) ─────────────────────────────────────
data/tfl_merged.csv
data/real/
data/collection.log

# Keep the data folder structure
!data/.gitkeep

# ── IDE and editor files ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Test coverage ─────────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*

# ── AI tools ─────────────────────────────────────────────────────
.claude
.gemini